# Frontend env — copy to .env.local for local dev.
# Set VITE_API_BASE_URL to the backend you want to talk to.
# Set VITE_USE_MOCKS=true to enable MSW (pre-Phase-1.5 frontend-only mode).
# Set VITE_USE_MOCKS=false (or omit) once the real backend is running.
VITE_API_BASE_URL=http://localhost:3000
VITE_USE_MOCKS=false
VITE_DEFAULT_LOCALE=en
