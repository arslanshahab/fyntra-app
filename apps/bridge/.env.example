# Bridge environment — copy to .env and fill in.
# Leave FYNTRA_API_URL empty to run the bridge as a local-only WS source
# (the original Phase 1 behavior). The Simulate Tap UI still works.

FYNTRA_API_URL=http://localhost:3000

# Plaintext device token. Get one by running `pnpm -F api db:seed` and
# capturing stdout — that's the only place the plaintext is shown.
FYNTRA_DEVICE_TOKEN=

# 'in' | 'out' | 'both'. The reader can't disambiguate; for 'both' the
# bridge defaults each tap to direction='in'. Set to 'in' or 'out'
# explicitly if the reader sits at an entry-only or exit-only gate.
FYNTRA_DEVICE_DIRECTION=both
